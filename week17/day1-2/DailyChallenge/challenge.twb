      <aliases enabled='yes' />
      <column caption='2020 Units Sold' datatype='integer' name='[2020_units_sold]' role='measure' type='quantitative' />
      <column caption='2021 Start Stock' datatype='integer' name='[2021_start_stock]' role='measure' type='quantitative' />
      <column caption='Advertisement Costs' datatype='real' name='[Advertisement_Costs]' role='measure' type='quantitative' />
      <column caption='Cost of Goods Sold' datatype='real' name='[Calculation_2608109355393024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Raw_Material_Cost] + [Factory_Labor_Costs] + [Factory_Equipment_Rent_Costs] + [Distribution_Costs]' />
      </column>
      <column caption='Profit' datatype='real' name='[Calculation_2608109355515905]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity] * [Retail_Price]' />
      </column>
      <column caption='Inventery Turnover' datatype='real' name='[Calculation_2608109355761666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Quantity]) / AVG([2021_start_stock])' />
      </column>
      <column caption='% Profits' datatype='real' name='[Calculation_2608109356355587]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Calculation_2608109355515905])) / TOTAL(SUM([Calculation_2608109355515905]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='ABC' datatype='string' name='[Calculation_2608109357039620]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2608109356355587] &lt;= 0.8 THEN &quot;A&quot;&#13;&#10;ELSEIF [Calculation_2608109356355587] &lt;= 0.95 THEN &quot;B&quot;&#13;&#10;ELSE &quot;C&quot; END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
